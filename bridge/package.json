{
  "name": "@jatsoca/risco-bridge",
  "displayName": "Risco Bridge",
  "version": "0.13.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "description": "Core bridge for direct communication with RISCO control panels.",
  "directories": {
    "doc": "doc",
    "example": "examples",
    "lib": "dist"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=10"
  },
  "publishConfig": {
    "cache": "~/.npm",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jatsoca/Risco_Stack_RPi_V2.git"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc-watch",
    "start": "tsc && node ./dist/main.js"
  },
  "keywords": [
    "risco",
    "lan",
    "alarm",
    "tcp/ip",
    "agility",
    "wicomm",
    "wicommpro",
    "lightsys",
    "prosysplus",
    "gtplus"
  ],
  "author": "Jaime Acosta",
  "license": "MIT",
  "homepage": "https://github.com/jatsoca/Risco_Stack_RPi_V2#readme",
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.1",
    "@types/node": "^17.0.2",
    "tsc-watch": "^4.6.0",
    "typescript": "^4.5.4"
  },
  "dependencies": {
    "tiny-typed-emitter": "^2.1.0",
    "tslib": "^2.3.1"
  }
}
