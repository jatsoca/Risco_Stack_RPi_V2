{
  "log": "info",
  "logColorize": true,
  "panel_name": "Risco Alarm",
  "heartbeat_interval_ms": 30000,
  "web": {
    "enable": true,
    "http_port": 1001,
    "ws_path": "/ws"
  },
  "modbus": {
    "enable": true,
    "port": 502,
    "host": "0.0.0.0"
  },
  "panel": {
    "panelIp": "172.16.85.2",
    "panelPort": 1000,
    "panelPassword": 5678,
    "panelId": "0001",
    "socketMode": "direct",
    "watchDogInterval": 5000,
    "commandsLog": true,
    "partitionCommandMode": "probe",
    "partitionCommandStrategy": "equals_star_decimal",
    "partitionCommandProbeOrder": [
      "equals_star_decimal",
      "colon_decimal",
      "colon_zero_pad_3",
      "equals_zero_pad_3",
      "equals_hex_zero_pad_2",
      "p_suffix_equals_plain",
      "p_suffix_equals_zero_pad_3",
      "p_suffix_colon_decimal",
      "p_suffix_colon_zero_pad_3",
      "p_suffix_equals_hex_zero_pad_2",
      "equals_plain"
    ]
  },
  "zones": {
    "default": {
      "off_delay": 0,
      "name_prefix": ""
    }
  }
}
